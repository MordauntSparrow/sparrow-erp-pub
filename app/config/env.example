# Copy to .env (same directory). Never commit real secrets.

# --- Core ---
FLASK_ENV=development
# SECRET_KEY=          # required in production (strong random)
# JWT_SECRET_KEY=      # optional; separates API token signing from session secret

# --- Database ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=sparrow_erp
# DB_POOL_SIZE=

# --- Redis (sessions, rate limits) ---
# REDIS_URL=
# RATELIMIT_STORAGE_URI=   # defaults to REDIS_URL if unset

# --- Cookies (HTTPS in production) ---
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_SECURE=false   # local HTTP only

# --- CORS / Socket.IO (cross-origin browser clients only) ---
# CORS_ALLOWED_ORIGINS=https://app.example.com
# SOCKETIO_CORS_ORIGINS=https://app.example.com

# --- Security headers (admin Flask app) ---
# SECURITY_HEADERS_ENABLED=true
# ENABLE_HSTS=true              # only when site is always HTTPS end-to-end
# HSTS_MAX_AGE=31536000
# X_FRAME_OPTIONS=SAMEORIGIN

# --- Rate limits ---
# RATE_LIMIT=200 per minute
# API_LOGIN_RATE_LIMIT=10 per minute
# FORM_LOGIN_RATE_LIMIT=5 per minute
# PASSWORD_RESET_RATE_LIMIT=3 per hour
#
# Targeted scanner guard: temporary IP ban for repeated exploit-probe paths
# such as /.env, /.git/*, wp-*, swagger/openapi probes, Vite manifests, etc.
# SPARROW_SCANNER_GUARD_ENABLED=true
# SPARROW_SCANNER_BAN_THRESHOLD=12
# SPARROW_SCANNER_WINDOW_SECONDS=600
# SPARROW_SCANNER_BAN_SECONDS=3600
# SPARROW_SCANNER_BLOCK_STATUS=404

# --- GitLab updates / marketplace ---
# Optional: app ships with official-registry read defaults when these are unset (UpdateManager).
# GITLAB_USERNAME=
# GITLAB_PASSWORD=
# GITLAB_TOKEN=
# Optional: read-only token used when GITLAB_TOKEN is unset (e.g. Railway/host env for official plugin registry).
# SPARROW_OFFICIAL_REGISTRY_TOKEN=
# GITLAB_PROJECT_ID=
# CORE_PROJECT_ID=
# CORE_MANIFEST_REMOTE_URL=

# --- Monitoring ---
# SENTRY_DSN=

# --- Email ---
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true

# --- Time Billing email (optional; uses Core SMTP above) ---
# TIME_BILLING_MODULE_EMAILS_DISABLED=0
# Comma-separated inboxes for “timesheet submitted” alerts (defaults to admin/superuser users).
# TIME_BILLING_NOTIFY_EMAILS=
# Absolute site URL for links in Time Billing emails (falls back to SPARROW_PUBLIC_BASE_URL).
# TIME_BILLING_PUBLIC_BASE_URL=
#
# Industry-tagged Time & Billing starter packs (medical “Care visit”, cleaning job types, etc.):
# default is off so init_db / upgrade does not insert them on every fresh database.
# SPARROW_ENABLE_TIME_BILLING_INDUSTRY_SEEDS=1
# Re-apply packs on next upgrade (clears one-shot ledger marker first).
# SPARROW_FORCE_TIME_BILLING_INDUSTRY_SEEDS=1
#
# When set, scheduling updates also INSERT missing Cura operational roster rows (additive only;
# requires Medical / Cura tables and a linked ``cura_operational_event_id`` on the run sheet or CRM plan).
# SPARROW_SCHEDULING_CURA_ROSTER_SYNC=1

# --- HR: register checks ---
# Set to 0 / false / no / off to disable HCPC Online Register lookups.
# HCPC_REGISTER_API_ENABLED=true
# HCPC_REGISTER_API_BASE=https://prod2online-apm.hcpc-uk.org/online-register
# HCPC_REGISTER_TIMEOUT_SECONDS=30

# --- Railway ---
# RAILWAY_ENVIRONMENT=production

# --- LLM / AI assistants (optional; Employee Portal, Scheduling, etc.) ---
# Uses the OpenAI Python SDK against any OpenAI-compatible API (OpenAI, OpenRouter, Gemini, Azure…).
# Optional: set "Chat model id" in Core module settings (admin UI) to override OPENAI_MODEL without editing .env.
#
# --- Fleet: UK MOT + DVLA lookup (optional; vehicle form “lookup registration”) ---
# DVLA Vehicle Enquiry Service — https://developer-portal.driver-vehicle-licensing.api.gov.uk/
# FLEET_UK_DVLA_API_KEY=
# FLEET_UK_DVLA_API_URL=https://driver-vehicle-licensing.api.gov.uk/vehicle-enquiry/v1/vehicles
#
# DVSA MOT History API — new registrations use Entra ID + API key on each call (see DVSA docs).
# FLEET_UK_MOT_API_KEY=
# FLEET_UK_MOT_CLIENT_ID=
# FLEET_UK_MOT_CLIENT_SECRET=
# FLEET_UK_MOT_TOKEN_URL=https://login.microsoftonline.com/<tenant>/oauth2/v2.0/token
# FLEET_UK_MOT_SCOPE=https://tapi.dvsa.gov.uk/.default
# FLEET_UK_MOT_API_BASE=https://tapi.dvsa.gov.uk
#
# Legacy MOT trade API (x-api-key only): omit the four OAuth vars; optional base:
# FLEET_UK_MOT_API_BASE=https://beta.check-mot.service.gov.uk
#
# Hide the vehicle page “Official MOT (DVSA)” tab only (e.g. server DNS cannot reach tapi.dvsa.gov.uk).
# Form “UK registration lookup” is unchanged. Values that hide: 0, false, no, off, disabled, hide.
# FLEET_UK_MOT_HISTORY_UI=0
#
# After repeated DVSA infrastructure failures, Sparrow automatically hides the Official MOT tab for
# ~15 minutes (circuit breaker). Set to 0/false/off to always attempt the tab (for debugging).
# FLEET_UK_MOT_CIRCUIT=0
#
# Troubleshooting MOT: full tracebacks + HTTP response bodies (no API keys/tokens) log under
# logger name fleet_management.uk_lookup — watch your app server stderr or log file.

# Paid OpenAI:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
#
# OpenRouter (many models, often free tiers) — https://openrouter.ai/
# OPENAI_API_KEY=<openrouter key>
# OPENAI_BASE_URL_PRESET=openrouter
# OPENAI_MODEL=google/gemini-2.0-flash-001:free
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_SITE_TITLE=Sparrow ERP
#
# Gemini free tier (Google AI Studio key) — https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# OPENAI_BASE_URL_PRESET=gemini
# OPENAI_MODEL=gemini-2.0-flash
#
# Aliases if OPENAI_API_KEY is empty: SPARROW_OPENAI_API_KEY, GEMINI_API_KEY, GOOGLE_API_KEY
# Or set OPENAI_BASE_URL explicitly instead of *_PRESET.


# --- Optional dev only ---
# SPARROW_AUTO_PIP_INSTALL=false

# Copy to .env and adjust. See create_app.py for full behaviour.

# --- Production ---
# FLASK_DEBUG=0
# SESSION_COOKIE_SECURE=true
# TB_CONTRACTOR_SEARCH_RATE_LIMIT=60 per minute
# TB_ADMIN_CONTRACTOR_SEARCH_RATE_LIMIT=120 per minute
# RATELIMIT_STORAGE_URI=redis://localhost:6379/1
# REDIS_URL=redis://localhost:6379/0

# HTTPS / HSTS (optional; reverse proxy TLS still required)
# ENABLE_HSTS=1

# what3words — optional; enables lat/lng from /// addresses in Ventus Response (WHAT3WORDS_API_KEY is an alias)
# W3W_API_KEY=

# --- Ventus MDT PWA Web Push (optional) ---
# Requires: pip install -r requirements.txt (includes pywebpush), HTTPS in production, and the MDT frontend on a secure origin.
# Generate keys on the server (Python, from repo root):  python scripts/generate_ventus_mdt_vapid.py
# Or with Node:  npx -y web-push generate-vapid-keys
# Public key is returned to clients via GET /api/mdt/push/vapid-public-key; keep the private key secret.
# VENTUS_MDT_VAPID_PUBLIC_KEY=
# VENTUS_MDT_VAPID_PRIVATE_KEY=
# Web Push "subscriber" claim — must be mailto: or https: (operational contact for push services).
# VENTUS_MDT_VAPID_SUBJECT=mailto:mdt@yourdomain.example

# --- Employee Portal PWA Web Push (optional) ---
# Same stack as Ventus MDT: pywebpush + HTTPS. Scoped to /employee-portal/ only.
# Generate keys:  python scripts/generate_ventus_mdt_vapid.py  (reuse keys only if you accept shared VAPID subscriber; otherwise generate a dedicated pair)
# Or:  npx -y web-push generate-vapid-keys
# EMPLOYEE_PORTAL_VAPID_PUBLIC_KEY=
# EMPLOYEE_PORTAL_VAPID_PRIVATE_KEY=
# EMPLOYEE_PORTAL_VAPID_SUBJECT=mailto:portal@yourdomain.example
